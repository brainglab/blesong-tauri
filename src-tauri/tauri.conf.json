{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/v2/tooling/cli/schema.json",
  "productName": "Blesong",
  "version": "1.0.0",
  "identifier": "com.blesong.app",
  "build": {
    "frontendDist": "../blesong-angular/dist/blesong/browser",
    "beforeBuildCommand": "cd blesong-angular && npm run prod",
    "beforeDevCommand": "cd blesong-angular && npx ng serve --port 4200",
    "devUrl": "http://localhost:4200"
  },
  "app": {
    "windows": [
      {
        "title": "Blesong",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/data.sqlite"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  }
}